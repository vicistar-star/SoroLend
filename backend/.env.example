# ─── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Database (PostgreSQL) ───────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sorolend
DB_USER=sorolend
DB_PASSWORD=sorolend_secret

# ─── Cache (Redis) ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m

# ─── Stellar ─────────────────────────────────────────
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROLEND_LENDING_POOL_ID=
SOROLEND_COLLATERAL_MANAGER_ID=
SOROLEND_PRICE_ORACLE_ID=

# ─── Challenge ───────────────────────────────────────
CHALLENGE_TTL_SECONDS=300
CHALLENGE_PREFIX=sorolend:auth:challenge:
